{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>cerbos/renovate",
        "group:allNonMajor",
        ":combinePatchMinorReleases"
    ],
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "GitHub Actions deps",
            "groupSlug": "gh-actions-deps"
        },
        {
            "description": "Opt-out of go.mod Go version updates: https://github.com/renovatebot/renovate/issues/16715",
            "matchManagers": [
                "gomod"
            ],
            "matchDepTypes": [
                "golang"
            ],
            "enabled": false
        },
        {
            "matchManagers": [
                "gomod"
            ],
            "groupName": "Go deps",
            "groupSlug": "go-deps"
        },
        {
            "description": "github.com/lestrrat-go/jwx/v4 requires Go 1.26 with GOEXPERIMENT=jsonv2",
            "matchPackageNames": ["github.com/lestrrat-go/jwx/v3"],
            "matchUpdateTypes": ["major"],
            "enabled": false
        }
    ],
    "labels": [
        "kind/chore",
        "area/dependencies",
        "bots"
    ]
}
